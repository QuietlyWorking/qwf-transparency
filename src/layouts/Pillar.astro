---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  accentColor: string;
  pillarSlug: string;
}

const { title, description, accentColor, pillarSlug } = Astro.props;
---

<Base title={title} description={description}>
  <div class="pillar-page">
    <header class="pillar-header" style={`--accent: ${accentColor}`}>
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span class="current">{title}</span>
      </nav>
      <h1>{title}</h1>
      <p class="pillar-desc">{description}</p>
    </header>

    <div class="pillar-content">
      <slot />
    </div>
  </div>
</Base>

<style>
  .pillar-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--accent, var(--border-color));
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--dim-star);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-secondary);
  }

  .breadcrumb a:hover {
    color: var(--aurora-teal);
  }

  .breadcrumb .sep {
    margin: 0 0.5rem;
  }

  .pillar-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.75rem;
  }

  .pillar-desc {
    color: var(--text-secondary);
    font-size: 1.15rem;
    max-width: 40rem;
  }

  .pillar-content {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .pillar-header h1 {
      font-size: 1.75rem;
    }

    .pillar-content {
      grid-template-columns: 1fr;
    }
  }
</style>
