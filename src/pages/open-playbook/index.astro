---
import Pillar from '@/layouts/Pillar.astro';
import PillarCard from '@/components/PillarCard.astro';
import { getCollection } from 'astro:content';

const pages = await getCollection('pages', (entry) =>
  entry.data.pillar === 'open-playbook'
);

const sorted = pages.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Pillar
  title="The Open Playbook"
  description="Our tools, costs, and SOPs... published so you can copy what works for your organization."
  accentColor="var(--aurora-teal)"
  pillarSlug="open-playbook"
>
  {sorted.map(page => (
    <PillarCard
      title={page.data.title}
      description={page.data.description}
      slug={page.data.slug}
      pillar={page.data.pillar}
      tags={page.data.tags}
      hook={page.data.hook}
    />
  ))}
</Pillar>
