---
import Pillar from '@/layouts/Pillar.astro';
import PillarCard from '@/components/PillarCard.astro';
import EcosystemMap from '@/components/islands/EcosystemMap.svelte';
import { getCollection } from 'astro:content';

const pages = await getCollection('pages', (entry) =>
  entry.data.pillar === 'living-proof'
);

const sorted = pages.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Load ecosystem data
let ecosystemData: Record<string, any> = {};
try {
  ecosystemData = await import('@/data/ecosystem.json');
} catch { /* graceful fallback */ }

const hasEcosystem = ecosystemData?.summary != null;
---

<Pillar
  title="Living Proof"
  description="See our systems running. Our values, programs, and ecosystem health... updated continuously."
  accentColor="var(--cosmic-magenta)"
  pillarSlug="living-proof"
>
  {hasEcosystem && (
    <div class="ecosystem-section">
      <h2>QWF Ecosystem</h2>
      <EcosystemMap client:visible data={ecosystemData} />
    </div>
  )}

  {sorted.map(page => (
    <PillarCard
      title={page.data.title}
      description={page.data.description}
      slug={page.data.slug}
      pillar={page.data.pillar}
      tags={page.data.tags}
    />
  ))}
</Pillar>

<style>
  .ecosystem-section {
    grid-column: 1 / -1;
    margin-bottom: 1rem;
  }

  .ecosystem-section h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 1rem;
  }
</style>
